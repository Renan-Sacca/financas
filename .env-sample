# ===========================================
# CONFIGURAÇÕES DE EMAIL SMTP
# ===========================================

# Servidor SMTP (Gmail recomendado)
SMTP_SERVER=smtp.gmail.com

# Porta SMTP (587 para TLS, 465 para SSL)
SMTP_PORT=587

# Seu email completo
EMAIL_USER=

# Senha de app do Gmail (NÃO use sua senha normal)
EMAIL_PASSWORD=

# ===========================================
# CONFIGURAÇÕES DE SEGURANÇA JWT
# ===========================================

# Chave secreta para assinar tokens JWT (gere uma aleatória)
SECRET_KEY=

# ===========================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ===========================================

# URL base da aplicação (para links de email)
BASE_URL=BASE_URL=

# Origens permitidas para o CORS (domínios oficiais)
ALLOWED_ORIGINS=

# ===========================================
# CONFIGURAÇÕES DO BANCO DE DADOS MYSQL
# ===========================================

# Configurações do MySQL na VPS
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=